# Copy to .env and fill in real values. .env is gitignored — never commit it.
# In GitHub Actions, set these as repository secrets instead of using a file.

# Global Forest Watch Data API key — https://www.globalforestwatch.org/ (Data API)
GFW_API_KEY=

# NASA FIRMS API key — https://firms.modis.gov/api/ (used by fetch_fire.py)
FIRMS_API_KEY=
